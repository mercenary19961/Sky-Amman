APP_NAME="Sky Amman"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — local dev uses 'log' (writes to storage/logs/laravel.log instead of
# sending). Production uses 'resend' with a verified sending domain.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@skyamman.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

# Cloudflare Turnstile — leave empty in dev to skip verification, OR use the
# official always-pass test keys so the widget renders without polluting prod
# analytics:
#   site:    1x00000000000000000000AA
#   secret:  1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Inertia SSR — set to false to disable SSR even in production builds.
INERTIA_SSR_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
