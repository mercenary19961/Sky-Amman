APP_NAME="Sky Amman"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — local dev uses 'log' (writes to storage/logs/laravel.log instead of
# sending). Production uses 'resend' with a verified sending domain.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@skyamman.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare Turnstile — leave empty in dev to skip verification, OR use the
# official always-pass test keys so the widget renders without polluting prod
# analytics:
#   site:    1x00000000000000000000AA
#   secret:  1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Tag Manager container (GTM-XXXXXXX). Leave EMPTY in dev — the snippet
# is only rendered when this is set, so local browsing never pollutes analytics.
# The container is excluded from /admin/* so staff sessions aren't counted as
# site traffic. GA4 and any other tags are configured inside the GTM UI.
# NOTE: new third-party tags added in GTM still need a CSP entry in
# app/Http/Middleware/SecurityHeaders.php or the browser silently blocks them.
GTM_CONTAINER_ID=

# CookieYes consent banner (the client_data ID from the script CookieYes gives
# you, NOT the whole tag). Empty = no banner, so dev is unaffected. Loads before
# GTM so Google Consent Mode defaults are set before any tag fires.
# ⚠️ Per-domain: mint a new site in CookieYes for skyamman.com. Reusing another
# project's ID reports this site's consent into that project's account.
COOKIEYES_SITE_ID=

# Inertia SSR. OFF by default (client-side rendering). In production a dedicated
# Node sidecar service runs `node bootstrap/ssr/ssr.js` (Railway: sky-amman-ssr,
# private port 13714) and these are set on the MAIN app service:
#   INERTIA_SSR_ENABLED=true
#   INERTIA_SSR_URL=http://sky-amman-ssr.railway.internal:13714
# To test SSR locally: set INERTIA_SSR_ENABLED=true and run
# `php artisan inertia:start-ssr` in a second terminal (after `npm run build`).
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714
# Timeouts (seconds) for the call to the SSR sidecar — kept under Railway's ~15s
# proxy timeout so a hung sidecar falls back to client rendering instead of 502.
INERTIA_SSR_TIMEOUT=3
INERTIA_SSR_CONNECT_TIMEOUT=2

VITE_APP_NAME="${APP_NAME}"
